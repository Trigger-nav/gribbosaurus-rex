# /etc/gribbo/env — environment for the gribbo services.
# NOT in git once populated. chmod 640 root:gribbo.

# Race configs directory (defaults to <repo>/configs if unset)
#GRIBBO_CONFIG_DIR=/opt/gribbo/app/configs

# ---- future model API keys (see HANDOFF.md model roadmap) ----
# Météo-France portal (AROME 1.3km, ARPEGE, AROME-Antilles):
#METEOFRANCE_API_KEY=

# Met Office DataHub (UKV 1.5km):
#DATAHUB_API_KEY=

# Mistral / Meteo-Hub Italy (ICON-2i 2.2km):
#MISTRAL_API_KEY=
