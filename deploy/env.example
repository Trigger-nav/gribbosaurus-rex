# /etc/gribbo/env — environment for the gribbo services.
# NOT in git once populated. chmod 640 root:gribbo.

# Race configs directory (defaults to <repo>/configs if unset)
#GRIBBO_CONFIG_DIR=/opt/gribbo/app/configs

# ---- model API keys (see HANDOFF.md model roadmap) ----
# Météo-France portal (AROME 2.5km, ARPEGE 0.1°/0.25°, AROME-Antilles).
# RECOMMENDED: the permanent APPLICATION_ID — auto-exchanged for OAuth2
# tokens (raw tokens expire hourly and would break the 10-min arbiter):
#METEOFRANCE_APPLICATION_ID=
# Alternative simple/manual scheme (a key or fresh token used directly):
#METEOFRANCE_API_KEY=
#METEOFRANCE_AUTH=apikey        # or "bearer"
# Optional: opt into AROME 1.3km (4x the data — watch disk):
#GRIBBO_AROME_GRID=0.01
# Overseas AROME ids, if the smoke script shows the catalogue differs:
#GRIBBO_AROMEOM_SERVICE=DPPaquetAROMEOM
#GRIBBO_AROMEOM_MODEL=AROME-ANTILLES

# Met Office DataHub (UKV 2km, order-based). API key from the DataHub
# subscription: Manage -> "API details / Refresh credentials". Order name
# defaults to "ukv-channel"; override if you rename the order.
#DATAHUB_API_KEY=
#DATAHUB_ORDER_ID=ukv-channel

# Mistral / Meteo-Hub Italy (ICON-2i 2.2km):
#MISTRAL_API_KEY=
